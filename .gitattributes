# JC Budgeting client-downloads Git LFS rules
#
# Run these once in the repo before your first push:
#   git lfs install
#   git add .gitattributes
#
# If large files were already committed before LFS tracking was added, rewrite them with:
#   git lfs migrate import --include="*.exe,*.deb,linux/**/manual/desktop/JCBudgeting,linux/**/manual/server/app/JCBudgeting.Server,mac/**/manual/desktop/JCBudgeting,mac/**/manual/server/app/JCBudgeting.Server,mac/**/manual/desktop/JCBudgeting.app/Contents/MacOS/JCBudgeting"

*.exe filter=lfs diff=lfs merge=lfs -text
*.deb filter=lfs diff=lfs merge=lfs -text
linux/**/manual/desktop/JCBudgeting filter=lfs diff=lfs merge=lfs -text
linux/**/manual/server/app/JCBudgeting.Server filter=lfs diff=lfs merge=lfs -text
mac/**/manual/desktop/JCBudgeting filter=lfs diff=lfs merge=lfs -text
mac/**/manual/server/app/JCBudgeting.Server filter=lfs diff=lfs merge=lfs -text
mac/**/manual/desktop/JCBudgeting.app/Contents/MacOS/JCBudgeting filter=lfs diff=lfs merge=lfs -text
