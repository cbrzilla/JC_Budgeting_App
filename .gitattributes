# JC Budgeting client-downloads Git LFS rules
#
# This repo keeps the release assets in the releases folder, so those archives should be
# tracked with Git LFS instead of being committed as normal Git blobs.
#
# Run these once in the repo before your first push:
#   git lfs install
#   git add .gitattributes
#
# If large files were already committed before LFS tracking was added, rewrite them with:
#   git lfs migrate import --include="releases/*.zip,releases/*.tar.gz"

releases/*.zip filter=lfs diff=lfs merge=lfs -text
releases/*.tar.gz filter=lfs diff=lfs merge=lfs -text
